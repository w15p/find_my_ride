# Terraform state files — never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Variable files with real values - gitignored by default.
# Only *.tfvars.example is safe to commit (no real IPs, emails, key names).
*.tfvars
!*.tfvars.example

# Editor backup files (vim/emacs ~ suffix, .swp, .bak). The naive *.tfvars
# pattern above misses terraform.tfvars~ - a real bug that got the example
# template committed once. Catch all backup patterns here regardless of
# extension.
*~
*.swp
*.swo
*.bak

# Crash log files
crash.log
crash.*.log

# Generated plan files (can contain secrets in plaintext)
*.tfplan

# Override files — local developer overrides, not for sharing
override.tf
override.tf.json
*_override.tf
*_override.tf.json
